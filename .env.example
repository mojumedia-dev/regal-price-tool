# JWT Authentication
# REQUIRED: Set a strong, random secret (minimum 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-key-here-min-32-chars

# Server Configuration
# Optional: Port number (default: 3000)
PORT=3000

# Database
# Optional: Database directory path (default: ./db)
DB_DIR=./db

# Sync API Credentials (if using external sync)
# Note: Sync credentials may be stored separately - check sync modules
